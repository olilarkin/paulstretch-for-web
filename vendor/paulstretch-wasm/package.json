{
  "name": "@olilarkin/paulstretch-wasm",
  "version": "0.3.0",
  "description": "Paulstretch extreme time-stretching algorithm, compiled to WebAssembly via Emscripten",
  "type": "module",
  "main": "dist/paulstretch.js",
  "module": "dist/paulstretch.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/paulstretch.js",
      "default": "./dist/paulstretch.js"
    },
    "./paulstretch.wasm": "./dist/paulstretch.wasm",
    "./paulstretch.nosimd.wasm": "./dist/paulstretch.nosimd.wasm"
  },
  "files": [
    "dist/paulstretch.js",
    "dist/paulstretch.wasm",
    "dist/paulstretch.nosimd.wasm",
    "index.d.ts",
    "README.md"
  ],
  "keywords": [
    "audio",
    "time-stretch",
    "paulstretch",
    "wasm",
    "webassembly",
    "dsp"
  ],
  "author": "Oli Larkin",
  "license": "GPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olilarkin/libpaulstretch.git",
    "directory": "npm"
  },
  "homepage": "https://github.com/olilarkin/libpaulstretch#readme",
  "bugs": {
    "url": "https://github.com/olilarkin/libpaulstretch/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
